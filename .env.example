# ============================================
#   AURALIS AI - Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your values.
# NEVER share your .env file publicly.

# --- Security ---
# Change this to a long, random string (e.g. from https://generate.dev/keys)
AURALIS_API_KEY=your_strong_api_key_here

# --- Server ---
PORT=8000

# --- AI Models ---
# For local: http://localhost:11434
# For Docker: http://ollama:11434
OLLAMA_HOST=http://localhost:11434
